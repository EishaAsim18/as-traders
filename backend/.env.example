MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/as-traders?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string-in-production

# Optional — extra CORS origins (comma-separated)
# CORS_ORIGINS=https://my-custom-domain.com

ADMIN_NAME=Asim
