PORT=3000

# Production: MongoDB Atlas (NOT localhost)
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/as-traders?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/as-traders?retryWrites=true&w=majority

JWT_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Optional — extra CORS origins (comma-separated)
# CORS_ORIGINS=https://my-custom-domain.com

ADMIN_NAME=Asim
ADMIN_EMAIL=admin@astraders.pk
ADMIN_PHONE=03001234567
ADMIN_PASSWORD=admin123

# Customer bank details fallback is in assets/js/payment-info.js (live values come from admin account)

# Password reset emails (Gmail example — use App Password, not your normal password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=hello@astraders.pk
# SMTP_PASS=your-app-password
# SMTP_FROM="A & S Traders <hello@astraders.pk>"
# CUSTOMER_SITE_URL=https://as-traders.vercel.app
# ADMIN_SITE_URL=https://as-traders-admin.vercel.app
# SHOP_NAME=A & S Traders
